//@version=6
indicator("Basin Detector", "Basin Detector", overlay = true, max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)

//------------------------------------------------------------------------------
// Inputs
//------------------------------------------------------------------------------
pivotLeft = input.int(3, "Pivot Left Length", minval = 1)
pivotRight = input.int(3, "Pivot Right Length", minval = 1)

tolMode = input.string("ATR", "Equality Tolerance Mode", options = ["Percent", "ATR", "Ticks"])
tolValue = input.float(0.20, "Equality Tolerance Value", minval = 0.0, step = 0.01)

breakMode = input.string("ATR", "Breakout Tolerance Mode", options = ["Percent", "ATR", "Ticks"])
breakValue = input.float(0.35, "Breakout Tolerance Value", minval = 0.0, step = 0.01)
breakValidation = input.string("Close Outside", "Breakout Validation", options = ["Wick Break", "Close Outside", "Consecutive Closes"])
breakConsecutiveCloses = input.int(2, "Breakout Consecutive Closes", minval = 1, maxval = 10)

minPairBars = input.int(5, "Min Bars Between Pair Touches", minval = 1)
maxPairBars = input.int(80, "Max Bars Between Pair Touches", minval = 2)
minOverlapBars = input.int(4, "Minimum Overlap Bars", minval = 0)
minOverlapPct = input.float(25.0, "Minimum Overlap %", minval = 0.0, maxval = 100.0, step = 1.0)
minBasinDuration = input.int(10, "Minimum Basin Duration", minval = 1)
maxHeightAtr = input.float(3.0, "Maximum Basin Height (ATR)", minval = 0.1, step = 0.1)
touchToleranceFrac = input.float(0.18, "Boundary Interaction Tolerance (fraction of basin height)", minval = 0.01, maxval = 0.50, step = 0.01)
minCloseInsidePct = input.float(62.0, "Minimum Close-Inside %", minval = 0.0, maxval = 100.0, step = 1.0)
minBodyInsidePct = input.float(70.0, "Minimum Body-Inside %", minval = 0.0, maxval = 100.0, step = 1.0)
invalidateConsecutiveOutside = input.int(3, "Invalidate After Consecutive Closes Outside", minval = 1, maxval = 20)
maxOutsideClosesPct = input.float(28.0, "Max Outside Closes %", minval = 0.0, maxval = 100.0, step = 1.0)
maxOutsideBodiesPct = input.float(20.0, "Max Outside Bodies %", minval = 0.0, maxval = 100.0, step = 1.0)
minOscillationsActive = input.int(1, "Minimum Oscillations For Active Basin", minval = 0, maxval = 20)
minOscillationsConfirmed = input.int(2, "Minimum Oscillations For Confirmed Basin", minval = 0, maxval = 20)
prominenceLookback = input.int(6, "Anchor Prominence Lookback", minval = 2, maxval = 50)
minEqhPrecisionConfirm = input.float(55.0, "Minimum EQH Precision For Confirm", minval = 0.0, maxval = 100.0, step = 1.0)
minEqlPrecisionConfirm = input.float(55.0, "Minimum EQL Precision For Confirm", minval = 0.0, maxval = 100.0, step = 1.0)
minEqhProminenceConfirm = input.float(45.0, "Minimum EQH Prominence For Confirm", minval = 0.0, maxval = 100.0, step = 1.0)
minEqlProminenceConfirm = input.float(45.0, "Minimum EQL Prominence For Confirm", minval = 0.0, maxval = 100.0, step = 1.0)
strictBoundaryMode = input.bool(false, "Strict Boundary Confirmation Mode")

minPossibleScore = input.int(40, "Minimum Score For Possible Basin", minval = 0, maxval = 100)
minConfirmedScore = input.int(80, "Minimum Score For Confirmed Basin", minval = 0, maxval = 100)

maxHistoricalBasins = input.int(30, "Maximum Historical Basins", minval = 1, maxval = 100)

showPossible = input.bool(true, "Show Possible Basins")
showConfirmed = input.bool(true, "Show Confirmed Basins")
showMid = input.bool(true, "Show Midpoint Line")
showLabels = input.bool(true, "Show Labels")
showSweepMarkers = input.bool(true, "Show Sweep Markers")
debugMode = input.bool(false, "Debug Mode")
showMergeDebug = input.bool(false, "Show Merge Debug")

atrLength = input.int(14, "ATR Length", minval = 1)
rangeLookback = input.int(50, "Recent Range Lookback", minval = 5)

//------------------------------------------------------------------------------
// Constants and helpers
//------------------------------------------------------------------------------
STATE_CANDIDATE = 0
STATE_ACTIVE = 1
STATE_CONFIRMED = 2
STATE_TERMINATED = 3

atr = ta.atr(atrLength)
recentRange = ta.highest(high, rangeLookback) - ta.lowest(low, rangeLookback)

f_safeDiv(float numerator, float denominator) =>
    denominator == 0.0 ? 0.0 : numerator / denominator

f_clamp(float value, float minValue, float maxValue) =>
    math.max(minValue, math.min(maxValue, value))

f_tol(string mode, float value, float refPrice, float atrValue) =>
    mode == "Percent" ? refPrice * value * 0.01 : mode == "ATR" ? atrValue * value : syminfo.mintick * value

f_percent(float value) =>
    str.tostring(value, "#.0") + "%"

f_overlapBars(int aStart, int aEnd, int bStart, int bEnd) =>
    int overlapStart = math.max(aStart, bStart)
    int overlapEnd = math.min(aEnd, bEnd)
    math.max(0, overlapEnd - overlapStart + 1)

f_rangeSpan(int aStart, int aEnd, int bStart, int bEnd) =>
    math.max(aEnd, bEnd) - math.min(aStart, bStart) + 1

f_bodyInside(float topValue, float bottomValue) =>
    math.max(open, close) <= topValue and math.min(open, close) >= bottomValue

f_touchTop(float topValue, float bottomValue, float frac) =>
    float height = math.max(topValue - bottomValue, syminfo.mintick)
    float zone = math.max(height * frac, syminfo.mintick * 2.0)
    high >= topValue - zone

f_touchBottom(float topValue, float bottomValue, float frac) =>
    float height = math.max(topValue - bottomValue, syminfo.mintick)
    float zone = math.max(height * frac, syminfo.mintick * 2.0)
    low <= bottomValue + zone

f_heightTicks(float topValue, float bottomValue) =>
    math.round((topValue - bottomValue) / syminfo.mintick)

f_scoreFromDiff(float diffValue, float toleranceValue) =>
    float ratio = toleranceValue <= 0.0 ? (diffValue == 0.0 ? 1.0 : 0.0) : 1.0 - f_clamp(diffValue / toleranceValue, 0.0, 1.0)
    ratio * 100.0

f_makeLabelText(bool confirmed, int scoreValue, int widthBars, float topValue, float bottomValue) =>
    string stateText = confirmed ? "CB" : "PB"
    float percentHeight = topValue == 0.0 ? 0.0 : ((topValue - bottomValue) / topValue) * 100.0
    stateText + " " + str.tostring(scoreValue) + " | " + str.tostring(widthBars) + " bars | " + str.tostring(f_heightTicks(topValue, bottomValue)) + "t | " + f_percent(percentHeight)

f_debugLabelText(int state, int scoreValue, int widthBars, float topValue, float bottomValue, float closeRatio, float bodyRatio, int outsideCloseCount, int consecOutside, int oscillations) =>
    string stateText = state == STATE_CONFIRMED ? "CB" : state == STATE_ACTIVE ? "AB" : state == STATE_TERMINATED ? "TB" : "PB"
    stateText + " " + str.tostring(scoreValue) +
     "\nC " + f_percent(closeRatio) +
     " | B " + f_percent(bodyRatio) +
     "\nOC " + str.tostring(outsideCloseCount) +
     " | CO " + str.tostring(consecOutside) +
     "\nOSC " + str.tostring(oscillations) +
     " | W " + str.tostring(widthBars) +
     "\nH " + str.tostring(f_heightTicks(topValue, bottomValue)) + "t"

f_pivotProminenceScore(bool isHighPivot, float pivotPrice, int rightOffset, int lookbackBars, float atrValue) =>
    float opposingExtreme = isHighPivot ? ta.lowest(low, lookbackBars)[rightOffset] : ta.highest(high, lookbackBars)[rightOffset]
    float rawDistance = isHighPivot ? pivotPrice - opposingExtreme : opposingExtreme - pivotPrice
    float normalized = atrValue <= 0.0 ? 0.0 : rawDistance / atrValue
    f_clamp(normalized / 2.0 * 100.0, 0.0, 100.0)

//------------------------------------------------------------------------------
// Pivot and pair storage
//------------------------------------------------------------------------------
var highPivotBars = array.new_int()
var highPivotPrices = array.new_float()
var highPivotProminences = array.new_float()
var lowPivotBars = array.new_int()
var lowPivotPrices = array.new_float()
var lowPivotProminences = array.new_float()

var eqhBar1 = array.new_int()
var eqhBar2 = array.new_int()
var eqhPrice1 = array.new_float()
var eqhPrice2 = array.new_float()
var eqhAtr = array.new_float()
var eqhTolerance = array.new_float()
var eqhProminence1 = array.new_float()
var eqhProminence2 = array.new_float()

var eqlBar1 = array.new_int()
var eqlBar2 = array.new_int()
var eqlPrice1 = array.new_float()
var eqlPrice2 = array.new_float()
var eqlAtr = array.new_float()
var eqlTolerance = array.new_float()
var eqlProminence1 = array.new_float()
var eqlProminence2 = array.new_float()

//------------------------------------------------------------------------------
// Basin state storage
//------------------------------------------------------------------------------
var basinLeft = array.new_int()
var basinRight = array.new_int()
var basinLeftTime = array.new_int()
var basinRightTime = array.new_int()
var basinTop = array.new_float()
var basinBottom = array.new_float()
var basinStatus = array.new_int()
var basinScore = array.new_int()
var basinEqhStart = array.new_int()
var basinEqhEnd = array.new_int()
var basinEqlStart = array.new_int()
var basinEqlEnd = array.new_int()
var basinEqhPrecision = array.new_float()
var basinEqlPrecision = array.new_float()
var basinEqhProminence = array.new_float()
var basinEqlProminence = array.new_float()
var basinOverlapPct = array.new_float()
var basinInsideBars = array.new_int()
var basinTotalBars = array.new_int()
var basinTopTouches = array.new_int()
var basinBottomTouches = array.new_int()
var basinFlipCount = array.new_int()
var basinLastTouch = array.new_int()
var basinCreatedBar = array.new_int()
var basinClosedBar = array.new_int()
var basinHeightAtr = array.new_float()
var basinLastSweepBar = array.new_int()
var basinBreakAboveCount = array.new_int()
var basinBreakBelowCount = array.new_int()
var basinCloseInsideRatio = array.new_float()
var basinBodyInsideRatio = array.new_float()
var basinOutsideCloseCount = array.new_int()
var basinOutsideBodyCount = array.new_int()
var basinConsecutiveOutside = array.new_int()
var basinWasConfirmed = array.new_bool()
var basinId = array.new_int()
var basinMergeEvent = array.new_string()
var basinBox = array.new_box()
var basinTopLine = array.new_line()
var basinBottomLine = array.new_line()
var basinMidLine = array.new_line()
var basinLabel = array.new_label()

//------------------------------------------------------------------------------
// Drawing helpers
//------------------------------------------------------------------------------
f_boxBg(int state) =>
    state == STATE_CONFIRMED ? color.new(color.teal, 82) : state == STATE_ACTIVE ? color.new(color.blue, 86) : color.new(color.silver, 90)

f_borderColor(int state) =>
    state == STATE_CONFIRMED ? color.new(color.teal, 0) : state == STATE_ACTIVE ? color.new(color.blue, 10) : color.new(color.gray, 25)

f_midColor(int state) =>
    state == STATE_CONFIRMED ? color.new(color.aqua, 35) : state == STATE_ACTIVE ? color.new(color.blue, 40) : color.new(color.gray, 60)

f_labelColor(int state) =>
    state == STATE_CONFIRMED ? color.new(color.teal, 0) : state == STATE_ACTIVE ? color.new(color.blue, 15) : color.new(color.gray, 20)

f_visibleByState(int state) =>
    state == STATE_CONFIRMED ? showConfirmed : showPossible

f_deleteBasinObjects(int idx) =>
    box bx = array.get(basinBox, idx)
    line tl = array.get(basinTopLine, idx)
    line bl = array.get(basinBottomLine, idx)
    line ml = array.get(basinMidLine, idx)
    label lb = array.get(basinLabel, idx)
    if not na(bx)
        box.delete(bx)
    if not na(tl)
        line.delete(tl)
    if not na(bl)
        line.delete(bl)
    if not na(ml)
        line.delete(ml)
    if not na(lb)
        label.delete(lb)

f_removeBasinAt(int idx) =>
    f_deleteBasinObjects(idx)
    array.remove(basinLeft, idx)
    array.remove(basinRight, idx)
    array.remove(basinLeftTime, idx)
    array.remove(basinRightTime, idx)
    array.remove(basinTop, idx)
    array.remove(basinBottom, idx)
    array.remove(basinStatus, idx)
    array.remove(basinScore, idx)
    array.remove(basinEqhStart, idx)
    array.remove(basinEqhEnd, idx)
    array.remove(basinEqlStart, idx)
    array.remove(basinEqlEnd, idx)
    array.remove(basinEqhPrecision, idx)
    array.remove(basinEqlPrecision, idx)
    array.remove(basinEqhProminence, idx)
    array.remove(basinEqlProminence, idx)
    array.remove(basinOverlapPct, idx)
    array.remove(basinInsideBars, idx)
    array.remove(basinTotalBars, idx)
    array.remove(basinTopTouches, idx)
    array.remove(basinBottomTouches, idx)
    array.remove(basinFlipCount, idx)
    array.remove(basinLastTouch, idx)
    array.remove(basinCreatedBar, idx)
    array.remove(basinClosedBar, idx)
    array.remove(basinHeightAtr, idx)
    array.remove(basinLastSweepBar, idx)
    array.remove(basinBreakAboveCount, idx)
    array.remove(basinBreakBelowCount, idx)
    array.remove(basinCloseInsideRatio, idx)
    array.remove(basinBodyInsideRatio, idx)
    array.remove(basinOutsideCloseCount, idx)
    array.remove(basinOutsideBodyCount, idx)
    array.remove(basinConsecutiveOutside, idx)
    array.remove(basinWasConfirmed, idx)
    array.remove(basinId, idx)
    array.remove(basinMergeEvent, idx)
    array.remove(basinBox, idx)
    array.remove(basinTopLine, idx)
    array.remove(basinBottomLine, idx)
    array.remove(basinMidLine, idx)
    array.remove(basinLabel, idx)

f_pruneBasins() =>
    while array.size(basinLeft) > maxHistoricalBasins
        int pruneIdx = -1
        for i = 0 to array.size(basinLeft) - 1
            if array.get(basinStatus, i) == STATE_TERMINATED
                pruneIdx := i
                break
        f_removeBasinAt(pruneIdx == -1 ? 0 : pruneIdx)

f_drawBasin(int idx) =>
    int rawState = array.get(basinStatus, idx)
    bool wasConfirmed = array.get(basinWasConfirmed, idx)
    int state = rawState == STATE_TERMINATED and wasConfirmed ? STATE_CONFIRMED : rawState == STATE_TERMINATED ? STATE_ACTIVE : rawState
    bool visible = rawState != STATE_TERMINATED ? f_visibleByState(state) : true
    int leftEdge = array.get(basinLeftTime, idx)
    int rightEdge = array.get(basinRightTime, idx)
    float topValue = array.get(basinTop, idx)
    float bottomValue = array.get(basinBottom, idx)
    float midValue = (topValue + bottomValue) * 0.5
    int scoreValue = array.get(basinScore, idx)
    int widthBars = array.get(basinRight, idx) - array.get(basinLeft, idx) + 1
    float closeRatio = array.get(basinCloseInsideRatio, idx)
    float bodyRatio = array.get(basinBodyInsideRatio, idx)
    int outsideCloseCount = array.get(basinOutsideCloseCount, idx)
    int consecOutside = array.get(basinConsecutiveOutside, idx)
    int oscillations = array.get(basinFlipCount, idx)
    int idValue = array.get(basinId, idx)
    string mergeEvent = array.get(basinMergeEvent, idx)
    box bx = array.get(basinBox, idx)
    line tl = array.get(basinTopLine, idx)
    line bl = array.get(basinBottomLine, idx)
    line ml = array.get(basinMidLine, idx)
    label lb = array.get(basinLabel, idx)
    color bg = visible ? f_boxBg(state) : color.new(color.white, 100)
    color border = visible ? f_borderColor(state) : color.new(color.white, 100)
    color midColor = visible and showMid ? f_midColor(state) : color.new(color.white, 100)
    color labelColor = visible and showLabels ? f_labelColor(state) : color.new(color.white, 100)
    if na(bx)
        bx := box.new(leftEdge, topValue, rightEdge, bottomValue, xloc = xloc.bar_time, bgcolor = bg, border_color = border)
        tl := line.new(leftEdge, topValue, rightEdge, topValue, xloc = xloc.bar_time, color = border, width = state == STATE_CONFIRMED ? 2 : 1)
        bl := line.new(leftEdge, bottomValue, rightEdge, bottomValue, xloc = xloc.bar_time, color = border, width = state == STATE_CONFIRMED ? 2 : 1)
        ml := line.new(leftEdge, midValue, rightEdge, midValue, xloc = xloc.bar_time, color = midColor, style = line.style_dashed)
        lb := label.new(rightEdge, topValue, "", xloc = xloc.bar_time, style = label.style_label_down, color = labelColor, textcolor = color.white, size = size.tiny)
        array.set(basinBox, idx, bx)
        array.set(basinTopLine, idx, tl)
        array.set(basinBottomLine, idx, bl)
        array.set(basinMidLine, idx, ml)
        array.set(basinLabel, idx, lb)
    if not na(bx)
        box.set_left(bx, leftEdge)
        box.set_right(bx, rightEdge)
        box.set_top(bx, topValue)
        box.set_bottom(bx, bottomValue)
        box.set_bgcolor(bx, bg)
        box.set_border_color(bx, border)
    if not na(tl)
        line.set_xy1(tl, leftEdge, topValue)
        line.set_xy2(tl, rightEdge, topValue)
        line.set_color(tl, border)
        line.set_width(tl, state == STATE_CONFIRMED ? 2 : 1)
    if not na(bl)
        line.set_xy1(bl, leftEdge, bottomValue)
        line.set_xy2(bl, rightEdge, bottomValue)
        line.set_color(bl, border)
        line.set_width(bl, state == STATE_CONFIRMED ? 2 : 1)
    if not na(ml)
        line.set_xy1(ml, leftEdge, midValue)
        line.set_xy2(ml, rightEdge, midValue)
        line.set_color(ml, midColor)
    if not na(lb)
        label.set_x(lb, rightEdge)
        label.set_y(lb, topValue)
        string labelText = debugMode ? f_debugLabelText(rawState, scoreValue, widthBars, topValue, bottomValue, closeRatio, bodyRatio, outsideCloseCount, consecOutside, oscillations) : f_makeLabelText(state == STATE_CONFIRMED, scoreValue, widthBars, topValue, bottomValue)
        if debugMode
            labelText += "\nID " + str.tostring(idValue)
            if showMergeDebug and str.length(mergeEvent) > 0
                labelText += "\n" + mergeEvent
        label.set_text(lb, showLabels and visible ? labelText : "")
        label.set_color(lb, labelColor)
        label.set_textcolor(lb, color.white)

//------------------------------------------------------------------------------
// Pair helpers
//------------------------------------------------------------------------------
f_pairDuplicate(array<int> pairBar1, array<int> pairBar2, int bar1, int bar2) =>
    bool exists = false
    int pairCount = array.size(pairBar1)
    if pairCount > 0
        for i = pairCount - 1 to 0
            if array.get(pairBar1, i) == bar1 and array.get(pairBar2, i) == bar2
                exists := true
                break
    exists

f_addEqhPair(int bar1, int bar2, float price1, float price2, float atrAtPair, float tolerance) =>
    if not f_pairDuplicate(eqhBar1, eqhBar2, bar1, bar2)
        array.push(eqhBar1, bar1)
        array.push(eqhBar2, bar2)
        array.push(eqhPrice1, price1)
        array.push(eqhPrice2, price2)
        array.push(eqhAtr, atrAtPair)
        array.push(eqhTolerance, tolerance)
        array.push(eqhProminence1, 0.0)
        array.push(eqhProminence2, 0.0)

f_addEqlPair(int bar1, int bar2, float price1, float price2, float atrAtPair, float tolerance) =>
    if not f_pairDuplicate(eqlBar1, eqlBar2, bar1, bar2)
        array.push(eqlBar1, bar1)
        array.push(eqlBar2, bar2)
        array.push(eqlPrice1, price1)
        array.push(eqlPrice2, price2)
        array.push(eqlAtr, atrAtPair)
        array.push(eqlTolerance, tolerance)
        array.push(eqlProminence1, 0.0)
        array.push(eqlProminence2, 0.0)

f_basinExists(int eqhStart, int eqhEnd, int eqlStart, int eqlEnd) =>
    bool exists = false
    int basinCount = array.size(basinLeft)
    if basinCount > 0
        for i = basinCount - 1 to 0
            if array.get(basinEqhStart, i) == eqhStart and array.get(basinEqhEnd, i) == eqhEnd and array.get(basinEqlStart, i) == eqlStart and array.get(basinEqlEnd, i) == eqlEnd
                exists := true
                break
    exists

f_findSimilarBasin(float topValue, float bottomValue, int startBar, int endBar, float toleranceTop, float toleranceBottom) =>
    int matchIdx = -1
    int basinCount = array.size(basinLeft)
    if basinCount > 0
        for i = basinCount - 1 to 0
            int status = array.get(basinStatus, i)
            if status != STATE_TERMINATED
                float existingTop = array.get(basinTop, i)
                float existingBottom = array.get(basinBottom, i)
                int existingLeft = array.get(basinLeft, i)
                int existingRight = array.get(basinRight, i)
                bool topNear = math.abs(existingTop - topValue) <= toleranceTop
                bool bottomNear = math.abs(existingBottom - bottomValue) <= toleranceBottom
                int overlapBars = f_overlapBars(existingLeft, existingRight, startBar, endBar)
                int spanBars = f_rangeSpan(existingLeft, existingRight, startBar, endBar)
                float overlapPct = spanBars <= 0 ? 0.0 : f_safeDiv(overlapBars, spanBars) * 100.0
                if topNear and bottomNear and (overlapBars >= minOverlapBars or overlapPct >= math.max(minOverlapPct, 40.0))
                    matchIdx := i
                    break
    matchIdx

f_applyCandidateToBasin(int idx, int topStart, int topEnd, int botStart, int botEnd, int leftEdge, float topPrice, float bottomPrice, float eqhPrecision, float eqlPrecision, float eqhProminence, float eqlProminence, float overlapPct, float heightAtrValue, int candidateScore, string mergeText) =>
    array.set(basinLeft, idx, math.min(array.get(basinLeft, idx), leftEdge))
    array.set(basinRight, idx, bar_index)
    array.set(basinLeftTime, idx, math.min(array.get(basinLeftTime, idx), time[bar_index - leftEdge]))
    array.set(basinRightTime, idx, time)
    array.set(basinTop, idx, (array.get(basinTop, idx) + topPrice) * 0.5)
    array.set(basinBottom, idx, (array.get(basinBottom, idx) + bottomPrice) * 0.5)
    array.set(basinEqhStart, idx, math.min(array.get(basinEqhStart, idx), topStart))
    array.set(basinEqhEnd, idx, math.max(array.get(basinEqhEnd, idx), topEnd))
    array.set(basinEqlStart, idx, math.min(array.get(basinEqlStart, idx), botStart))
    array.set(basinEqlEnd, idx, math.max(array.get(basinEqlEnd, idx), botEnd))
    array.set(basinEqhPrecision, idx, math.max(array.get(basinEqhPrecision, idx), eqhPrecision))
    array.set(basinEqlPrecision, idx, math.max(array.get(basinEqlPrecision, idx), eqlPrecision))
    array.set(basinEqhProminence, idx, math.max(array.get(basinEqhProminence, idx), eqhProminence))
    array.set(basinEqlProminence, idx, math.max(array.get(basinEqlProminence, idx), eqlProminence))
    array.set(basinOverlapPct, idx, math.max(array.get(basinOverlapPct, idx), overlapPct))
    array.set(basinHeightAtr, idx, math.min(array.get(basinHeightAtr, idx), heightAtrValue))
    array.set(basinScore, idx, math.max(array.get(basinScore, idx), candidateScore))
    array.set(basinMergeEvent, idx, mergeText)

f_nextBasinId() =>
    int nextId = 1
    int basinCount = array.size(basinId)
    if basinCount > 0
        int maxId = array.get(basinId, 0)
        if basinCount > 1
            for i = 1 to basinCount - 1
                maxId := math.max(maxId, array.get(basinId, i))
        nextId := maxId + 1
    nextId

f_initialBasinScore(float eqhPrecision, float eqlPrecision, float overlapPct, float heightAtrValue, int durationBars) =>
    float durationScore = f_clamp(f_safeDiv(durationBars, minPairBars * 2.0) * 100.0, 0.0, 100.0)
    float heightScore = heightAtrValue >= maxHeightAtr ? 0.0 : (1.0 - heightAtrValue / maxHeightAtr) * 100.0
    float score = eqhPrecision * 0.28 + eqlPrecision * 0.28 + overlapPct * 0.24 + heightScore * 0.12 + durationScore * 0.08
    math.round(f_clamp(score, 0.0, 100.0))

f_dynamicBasinScore(int idx) =>
    float eqhPrecision = array.get(basinEqhPrecision, idx)
    float eqlPrecision = array.get(basinEqlPrecision, idx)
    float eqhProminence = array.get(basinEqhProminence, idx)
    float eqlProminence = array.get(basinEqlProminence, idx)
    float overlapPct = array.get(basinOverlapPct, idx)
    float closeInsideRatio = array.get(basinCloseInsideRatio, idx)
    float bodyInsideRatio = array.get(basinBodyInsideRatio, idx)
    int topTouches = array.get(basinTopTouches, idx)
    int bottomTouches = array.get(basinBottomTouches, idx)
    int oscillationCount = array.get(basinFlipCount, idx)
    float heightAtrValue = array.get(basinHeightAtr, idx)
    int durationBars = array.get(basinRight, idx) - array.get(basinLeft, idx) + 1
    float touchScore = f_clamp(f_safeDiv(topTouches + bottomTouches, 6.0) * 100.0, 0.0, 100.0)
    float oscillationScore = f_clamp(f_safeDiv(oscillationCount, 4.0) * 100.0, 0.0, 100.0)
    float heightScore = heightAtrValue >= maxHeightAtr ? 0.0 : (1.0 - heightAtrValue / maxHeightAtr) * 100.0
    float durationScore = f_clamp(f_safeDiv(durationBars, minBasinDuration * 2.0) * 100.0, 0.0, 100.0)
    float score = eqhPrecision * 0.10 + eqlPrecision * 0.10 + eqhProminence * 0.11 + eqlProminence * 0.11 + overlapPct * 0.10 + closeInsideRatio * 0.12 + bodyInsideRatio * 0.12 + touchScore * 0.07 + oscillationScore * 0.11 + heightScore * 0.08 + durationScore * 0.08
    math.round(f_clamp(score, 0.0, 100.0))

f_scanContinuousStart(int rawStart, float topValue, float bottomValue) =>
    int lookback = math.max(bar_index - rawStart, 0)
    int segmentStart = rawStart
    int totalBars = 0
    int closeInsideCount = 0
    int bodyInsideCount = 0
    int outsideCloseCount = 0
    int outsideBodyCount = 0
    int consecutiveOutside = 0
    int oscillationCount = 0
    int topTouches = 0
    int bottomTouches = 0
    int lastHalf = 0
    float midValue = (topValue + bottomValue) * 0.5
    float heightValue = math.max(topValue - bottomValue, syminfo.mintick)
    float touchZone = math.max(heightValue * touchToleranceFrac, syminfo.mintick * 2.0)
    if lookback >= 0
        for offset = lookback to 0
            float c = close[offset]
            float o = open[offset]
            float h = high[offset]
            float l = low[offset]
            bool closeInside = c <= topValue and c >= bottomValue
            bool bodyInside = math.max(o, c) <= topValue and math.min(o, c) >= bottomValue
            totalBars += 1
            closeInsideCount += closeInside ? 1 : 0
            bodyInsideCount += bodyInside ? 1 : 0
            outsideCloseCount += closeInside ? 0 : 1
            outsideBodyCount += bodyInside ? 0 : 1
            consecutiveOutside := closeInside ? 0 : consecutiveOutside + 1
            topTouches += h >= topValue - touchZone ? 1 : 0
            bottomTouches += l <= bottomValue + touchZone ? 1 : 0
            if closeInside or bodyInside
                int half = c >= midValue ? 1 : -1
                if lastHalf != 0 and half != lastHalf
                    oscillationCount += 1
                lastHalf := half
            float outsideClosePct = totalBars == 0 ? 0.0 : f_safeDiv(outsideCloseCount, totalBars) * 100.0
            float outsideBodyPct = totalBars == 0 ? 0.0 : f_safeDiv(outsideBodyCount, totalBars) * 100.0
            if consecutiveOutside >= invalidateConsecutiveOutside or outsideClosePct > maxOutsideClosesPct or outsideBodyPct > maxOutsideBodiesPct
                segmentStart := bar_index - offset + 1
                totalBars := 0
                closeInsideCount := 0
                bodyInsideCount := 0
                outsideCloseCount := 0
                outsideBodyCount := 0
                consecutiveOutside := 0
                oscillationCount := 0
                topTouches := 0
                bottomTouches := 0
                lastHalf := 0
    [segmentStart, totalBars, closeInsideCount, bodyInsideCount, outsideCloseCount, outsideBodyCount, consecutiveOutside, topTouches, bottomTouches, oscillationCount]

f_evaluateContinuity(int startBar, float topValue, float bottomValue) =>
    int lookback = math.max(bar_index - startBar, 0)
    int totalBars = 0
    int closeInsideCount = 0
    int bodyInsideCount = 0
    int outsideCloseCount = 0
    int outsideBodyCount = 0
    int consecutiveOutside = 0
    int topTouches = 0
    int bottomTouches = 0
    int oscillationCount = 0
    int lastHalf = 0
    int breakBar = na
    bool broken = false
    float midValue = (topValue + bottomValue) * 0.5
    float heightValue = math.max(topValue - bottomValue, syminfo.mintick)
    float touchZone = math.max(heightValue * touchToleranceFrac, syminfo.mintick * 2.0)
    if lookback >= 0
        for offset = lookback to 0
            float c = close[offset]
            float o = open[offset]
            float h = high[offset]
            float l = low[offset]
            bool closeInside = c <= topValue and c >= bottomValue
            bool bodyInside = math.max(o, c) <= topValue and math.min(o, c) >= bottomValue
            totalBars += 1
            closeInsideCount += closeInside ? 1 : 0
            bodyInsideCount += bodyInside ? 1 : 0
            outsideCloseCount += closeInside ? 0 : 1
            outsideBodyCount += bodyInside ? 0 : 1
            consecutiveOutside := closeInside ? 0 : consecutiveOutside + 1
            topTouches += h >= topValue - touchZone ? 1 : 0
            bottomTouches += l <= bottomValue + touchZone ? 1 : 0
            if closeInside or bodyInside
                int half = c >= midValue ? 1 : -1
                if lastHalf != 0 and half != lastHalf
                    oscillationCount += 1
                lastHalf := half
            float outsideClosePct = totalBars == 0 ? 0.0 : f_safeDiv(outsideCloseCount, totalBars) * 100.0
            float outsideBodyPct = totalBars == 0 ? 0.0 : f_safeDiv(outsideBodyCount, totalBars) * 100.0
            if not broken and (consecutiveOutside >= invalidateConsecutiveOutside or outsideClosePct > maxOutsideClosesPct or outsideBodyPct > maxOutsideBodiesPct)
                broken := true
                int currentBar = bar_index - offset
                breakBar := consecutiveOutside >= invalidateConsecutiveOutside ? currentBar - consecutiveOutside + 1 : currentBar
                break
    float closeInsideRatio = totalBars == 0 ? 0.0 : f_safeDiv(closeInsideCount, totalBars) * 100.0
    float bodyInsideRatio = totalBars == 0 ? 0.0 : f_safeDiv(bodyInsideCount, totalBars) * 100.0
    [totalBars, closeInsideCount, bodyInsideCount, outsideCloseCount, outsideBodyCount, consecutiveOutside, closeInsideRatio, bodyInsideRatio, topTouches, bottomTouches, oscillationCount, broken, breakBar]

f_tryCreateBasinFromPairs(int eqhIdx, int eqlIdx) =>
    int topStart = array.get(eqhBar1, eqhIdx)
    int topEnd = array.get(eqhBar2, eqhIdx)
    int botStart = array.get(eqlBar1, eqlIdx)
    int botEnd = array.get(eqlBar2, eqlIdx)
    int overlapBars = f_overlapBars(topStart, topEnd, botStart, botEnd)
    int spanBars = f_rangeSpan(topStart, topEnd, botStart, botEnd)
    float overlapPct = spanBars <= 0 ? 0.0 : f_safeDiv(overlapBars, spanBars) * 100.0
    float topPrice = math.avg(array.get(eqhPrice1, eqhIdx), array.get(eqhPrice2, eqhIdx))
    float bottomPrice = math.avg(array.get(eqlPrice1, eqlIdx), array.get(eqlPrice2, eqlIdx))
    float heightValue = topPrice - bottomPrice
    float basinAtr = math.avg(array.get(eqhAtr, eqhIdx), array.get(eqlAtr, eqlIdx))
    float heightAtrValue = basinAtr == 0.0 ? 999.0 : heightValue / basinAtr
    int leftEdge = math.min(math.min(topStart, topEnd), math.min(botStart, botEnd))
    int rightEdge = math.max(math.max(topStart, topEnd), math.max(botStart, botEnd))
    int durationBars = rightEdge - leftEdge + 1
    int candidateSpanBars = math.max(minPairBars, minOverlapBars + 1)
    float rangeCap = nz(recentRange, heightValue * 2.0)
    float eqhPrecision = f_scoreFromDiff(math.abs(array.get(eqhPrice1, eqhIdx) - array.get(eqhPrice2, eqhIdx)), array.get(eqhTolerance, eqhIdx))
    float eqlPrecision = f_scoreFromDiff(math.abs(array.get(eqlPrice1, eqlIdx) - array.get(eqlPrice2, eqlIdx)), array.get(eqlTolerance, eqlIdx))
    float eqhProminence = math.avg(array.get(eqhProminence1, eqhIdx), array.get(eqhProminence2, eqhIdx))
    float eqlProminence = math.avg(array.get(eqlProminence1, eqlIdx), array.get(eqlProminence2, eqlIdx))
    int initialScore = f_initialBasinScore(eqhPrecision, eqlPrecision, overlapPct, heightAtrValue, durationBars)
    bool overlapOk = overlapBars >= minOverlapBars or overlapPct >= minOverlapPct
    bool heightOk = heightValue > 0.0 and heightAtrValue <= maxHeightAtr and heightValue <= rangeCap * 0.95
    [continuousStart, continuousBars, continuousCloseInside, continuousBodyInside, continuousOutsideCloses, continuousOutsideBodies, continuousConsecutiveOutside, continuousTopTouches, continuousBottomTouches, continuousOscillations] = f_scanContinuousStart(leftEdge, topPrice, bottomPrice)
    float continuousCloseRatio = continuousBars == 0 ? 0.0 : f_safeDiv(continuousCloseInside, continuousBars) * 100.0
    float continuousBodyRatio = continuousBars == 0 ? 0.0 : f_safeDiv(continuousBodyInside, continuousBars) * 100.0
    bool durationOk = continuousBars >= candidateSpanBars
    bool containmentOk = continuousCloseRatio >= minCloseInsidePct and continuousBodyRatio >= minBodyInsidePct
    bool continuityAnchored = continuousStart <= math.min(topEnd, botEnd)
    bool exists = f_basinExists(topStart, topEnd, botStart, botEnd)
    float basinTol = math.max(array.get(eqhTolerance, eqhIdx), array.get(eqlTolerance, eqlIdx))
    int similarIdx = f_findSimilarBasin(topPrice, bottomPrice, continuousStart, bar_index, basinTol, basinTol)
    bool basinHandled = false
    if overlapOk and heightOk and durationOk and containmentOk and continuityAnchored and initialScore >= minPossibleScore and not exists
        if similarIdx != -1
            f_applyCandidateToBasin(similarIdx, topStart, topEnd, botStart, botEnd, continuousStart, topPrice, bottomPrice, eqhPrecision, eqlPrecision, eqhProminence, eqlProminence, overlapPct, heightAtrValue, initialScore, "Merged candidate")
            basinHandled := true
        else
            // Candidates only start where continuous containment begins, so disconnected ranges don't get merged together.
            int nextId = f_nextBasinId()
            array.push(basinLeft, continuousStart)
            array.push(basinRight, bar_index)
            array.push(basinLeftTime, time[bar_index - continuousStart])
            array.push(basinRightTime, time)
            array.push(basinTop, topPrice)
            array.push(basinBottom, bottomPrice)
            array.push(basinStatus, STATE_CANDIDATE)
            array.push(basinScore, initialScore)
            array.push(basinEqhStart, topStart)
            array.push(basinEqhEnd, topEnd)
            array.push(basinEqlStart, botStart)
            array.push(basinEqlEnd, botEnd)
            array.push(basinEqhPrecision, eqhPrecision)
            array.push(basinEqlPrecision, eqlPrecision)
            array.push(basinEqhProminence, eqhProminence)
            array.push(basinEqlProminence, eqlProminence)
            array.push(basinOverlapPct, overlapPct)
            array.push(basinInsideBars, 0)
            array.push(basinTotalBars, 0)
            array.push(basinTopTouches, 0)
            array.push(basinBottomTouches, 0)
            array.push(basinFlipCount, 0)
            array.push(basinLastTouch, 0)
            array.push(basinCreatedBar, bar_index)
            array.push(basinClosedBar, na)
            array.push(basinHeightAtr, heightAtrValue)
            array.push(basinLastSweepBar, na)
            array.push(basinBreakAboveCount, 0)
            array.push(basinBreakBelowCount, 0)
            array.push(basinCloseInsideRatio, continuousCloseRatio)
            array.push(basinBodyInsideRatio, continuousBodyRatio)
            array.push(basinOutsideCloseCount, continuousOutsideCloses)
            array.push(basinOutsideBodyCount, continuousOutsideBodies)
            array.push(basinConsecutiveOutside, continuousConsecutiveOutside)
            array.push(basinWasConfirmed, false)
            array.push(basinId, nextId)
            array.push(basinMergeEvent, "Created new basin")
            array.push(basinBox, na)
            array.push(basinTopLine, na)
            array.push(basinBottomLine, na)
            array.push(basinMidLine, na)
            array.push(basinLabel, na)
            f_pruneBasins()
            basinHandled := true
    basinHandled

//------------------------------------------------------------------------------
// Pivot detection and pair creation
//------------------------------------------------------------------------------
float ph = ta.pivothigh(high, pivotLeft, pivotRight)
float pl = ta.pivotlow(low, pivotLeft, pivotRight)
float highPivotProminenceNow = f_pivotProminenceScore(true, high[pivotRight], pivotRight, prominenceLookback, atr[pivotRight])
float lowPivotProminenceNow = f_pivotProminenceScore(false, low[pivotRight], pivotRight, prominenceLookback, atr[pivotRight])

if not na(ph)
    int pivotBar = bar_index - pivotRight
    float pivotAtr = atr[pivotRight]
    float pivotProminence = highPivotProminenceNow
    array.push(highPivotBars, pivotBar)
    array.push(highPivotPrices, ph)
    array.push(highPivotProminences, pivotProminence)
    if array.size(highPivotBars) > 1
        for i = array.size(highPivotBars) - 2 to 0
            int priorBar = array.get(highPivotBars, i)
            float priorPrice = array.get(highPivotPrices, i)
            float priorProminence = array.get(highPivotProminences, i)
            int spacing = pivotBar - priorBar
            if spacing > maxPairBars
                break
            if spacing >= minPairBars
                float tolerance = f_tol(tolMode, tolValue, math.avg(priorPrice, ph), pivotAtr)
                if math.abs(priorPrice - ph) <= tolerance
                    f_addEqhPair(priorBar, pivotBar, priorPrice, ph, pivotAtr, tolerance)
                    int newEqhIdx = array.size(eqhBar1) - 1
                    array.set(eqhProminence1, newEqhIdx, priorProminence)
                    array.set(eqhProminence2, newEqhIdx, pivotProminence)
                    if array.size(eqlBar1) > 0
                        for j = array.size(eqlBar1) - 1 to 0
                            if pivotBar - array.get(eqlBar1, j) > maxPairBars * 2
                                break
                            f_tryCreateBasinFromPairs(newEqhIdx, j)

if not na(pl)
    int pivotBar = bar_index - pivotRight
    float pivotAtr = atr[pivotRight]
    float pivotProminence = lowPivotProminenceNow
    array.push(lowPivotBars, pivotBar)
    array.push(lowPivotPrices, pl)
    array.push(lowPivotProminences, pivotProminence)
    if array.size(lowPivotBars) > 1
        for i = array.size(lowPivotBars) - 2 to 0
            int priorBar = array.get(lowPivotBars, i)
            float priorPrice = array.get(lowPivotPrices, i)
            float priorProminence = array.get(lowPivotProminences, i)
            int spacing = pivotBar - priorBar
            if spacing > maxPairBars
                break
            if spacing >= minPairBars
                float tolerance = f_tol(tolMode, tolValue, math.avg(priorPrice, pl), pivotAtr)
                if math.abs(priorPrice - pl) <= tolerance
                    f_addEqlPair(priorBar, pivotBar, priorPrice, pl, pivotAtr, tolerance)
                    int newEqlIdx = array.size(eqlBar1) - 1
                    array.set(eqlProminence1, newEqlIdx, priorProminence)
                    array.set(eqlProminence2, newEqlIdx, pivotProminence)
                    if array.size(eqhBar1) > 0
                        for j = array.size(eqhBar1) - 1 to 0
                            if pivotBar - array.get(eqhBar1, j) > maxPairBars * 2
                                break
                            f_tryCreateBasinFromPairs(j, newEqlIdx)

//------------------------------------------------------------------------------
// Basin lifecycle update
//------------------------------------------------------------------------------
var bool sweepHighSignal = false
var bool sweepLowSignal = false
var string sweepHighText = "SH"
var string sweepLowText = "SL"
sweepHighSignal := false
sweepLowSignal := false
sweepHighText := "SH"
sweepLowText := "SL"
float bestSweepScore = -1.0
int bestSweepPriority = -1

if array.size(basinLeft) > 0
    for i = 0 to array.size(basinLeft) - 1
        int state = array.get(basinStatus, i)
        float topValue = array.get(basinTop, i)
        float bottomValue = array.get(basinBottom, i)
        float breakoutTol = f_tol(breakMode, breakValue, math.avg(topValue, bottomValue), atr)
        bool active = state != STATE_TERMINATED

        if active
            [totalBars, closeInsideCount, bodyInsideCount, outsideCloseCount, outsideBodyCount, consecutiveOutside, closeInsideRatio, bodyInsideRatio, topTouches, bottomTouches, oscillationCount, continuityBroken, breakBar] = f_evaluateContinuity(array.get(basinLeft, i), topValue, bottomValue)
            array.set(basinRight, i, continuityBroken ? breakBar : bar_index)
            array.set(basinRightTime, i, continuityBroken ? time[bar_index - breakBar] : time)
            array.set(basinTotalBars, i, totalBars)
            array.set(basinInsideBars, i, closeInsideCount)
            array.set(basinTopTouches, i, topTouches)
            array.set(basinBottomTouches, i, bottomTouches)
            array.set(basinFlipCount, i, oscillationCount)
            array.set(basinCloseInsideRatio, i, closeInsideRatio)
            array.set(basinBodyInsideRatio, i, bodyInsideRatio)
            array.set(basinOutsideCloseCount, i, outsideCloseCount)
            array.set(basinOutsideBodyCount, i, outsideBodyCount)
            array.set(basinConsecutiveOutside, i, consecutiveOutside)

            int scoreValue = f_dynamicBasinScore(i)
            array.set(basinScore, i, scoreValue)
            int durationBars = array.get(basinRight, i) - array.get(basinLeft, i) + 1
            float eqhPrecision = array.get(basinEqhPrecision, i)
            float eqlPrecision = array.get(basinEqlPrecision, i)
            float eqhProminence = array.get(basinEqhProminence, i)
            float eqlProminence = array.get(basinEqlProminence, i)
            bool anchorPrecisionOk = eqhPrecision >= minEqhPrecisionConfirm and eqlPrecision >= minEqlPrecisionConfirm
            bool strictProminenceOk = eqhProminence >= minEqhProminenceConfirm and eqlProminence >= minEqlProminenceConfirm
            bool softProminenceOk = math.avg(eqhProminence, eqlProminence) >= math.avg(minEqhProminenceConfirm, minEqlProminenceConfirm) and math.min(eqhProminence, eqlProminence) >= math.min(minEqhProminenceConfirm, minEqlProminenceConfirm) * 0.65
            bool boundaryQualityOk = strictBoundaryMode ? (anchorPrecisionOk and strictProminenceOk) : (anchorPrecisionOk and softProminenceOk)
            bool continuityHealthy = closeInsideRatio >= minCloseInsidePct and bodyInsideRatio >= minBodyInsidePct
            bool activeReady = durationBars >= math.max(minPairBars, minOverlapBars + 1) and continuityHealthy and oscillationCount >= minOscillationsActive
            bool confirmReady = durationBars >= minBasinDuration and continuityHealthy and boundaryQualityOk and topTouches >= 2 and bottomTouches >= 2 and oscillationCount >= minOscillationsConfirmed and scoreValue >= minConfirmedScore
            if state == STATE_CANDIDATE and activeReady
                array.set(basinStatus, i, STATE_ACTIVE)
                state := STATE_ACTIVE
            if (state == STATE_CANDIDATE or state == STATE_ACTIVE) and confirmReady
                array.set(basinStatus, i, STATE_CONFIRMED)
                array.set(basinWasConfirmed, i, true)
                state := STATE_CONFIRMED

            bool wickBreakUp = high > topValue + breakoutTol
            bool wickBreakDn = low < bottomValue - breakoutTol
            bool closeBreakUp = close > topValue + breakoutTol
            bool closeBreakDn = close < bottomValue - breakoutTol
            bool invalidateUp = false
            bool invalidateDn = false

            if breakValidation == "Wick Break"
                invalidateUp := wickBreakUp
                invalidateDn := wickBreakDn
                array.set(basinBreakAboveCount, i, 0)
                array.set(basinBreakBelowCount, i, 0)
            else if breakValidation == "Close Outside"
                invalidateUp := closeBreakUp
                invalidateDn := closeBreakDn
                array.set(basinBreakAboveCount, i, 0)
                array.set(basinBreakBelowCount, i, 0)
            else
                int aboveCount = closeBreakUp ? array.get(basinBreakAboveCount, i) + 1 : 0
                int belowCount = closeBreakDn ? array.get(basinBreakBelowCount, i) + 1 : 0
                array.set(basinBreakAboveCount, i, aboveCount)
                array.set(basinBreakBelowCount, i, belowCount)
                invalidateUp := aboveCount >= breakConsecutiveCloses
                invalidateDn := belowCount >= breakConsecutiveCloses

            if showSweepMarkers
                int sweepPriority = state == STATE_CONFIRMED ? 1 : 0
                bool sweepHigh = wickBreakUp and close <= topValue and close >= bottomValue and array.get(basinLastSweepBar, i) != bar_index
                bool sweepLow = wickBreakDn and close >= bottomValue and close <= topValue and array.get(basinLastSweepBar, i) != bar_index
                bool winsSweepSlot = sweepPriority > bestSweepPriority or (sweepPriority == bestSweepPriority and array.get(basinScore, i) >= bestSweepScore)
                if (sweepHigh or sweepLow) and winsSweepSlot
                    bestSweepScore := array.get(basinScore, i)
                    bestSweepPriority := sweepPriority
                    sweepHighSignal := sweepHigh
                    sweepLowSignal := sweepLow
                    sweepHighText := "SH"
                    sweepLowText := "SL"
                    array.set(basinLastSweepBar, i, bar_index)

            if continuityBroken or invalidateUp or invalidateDn
                array.set(basinStatus, i, STATE_TERMINATED)
                array.set(basinRight, i, continuityBroken ? breakBar : bar_index)
                array.set(basinRightTime, i, continuityBroken ? time[bar_index - breakBar] : time)
                array.set(basinClosedBar, i, continuityBroken ? breakBar : bar_index)

        f_drawBasin(i)

plotshape(showSweepMarkers and sweepHighSignal, title = "Potential Sweep High", style = shape.triangledown, location = location.abovebar, color = color.new(color.orange, 0), size = size.tiny, text = "SH")
plotshape(showSweepMarkers and sweepLowSignal, title = "Potential Sweep Low", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "SL")
